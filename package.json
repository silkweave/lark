{
  "name": "@silkweave/lark",
  "version": "1.9.0",
  "description": "Silkweave Lark MCP & CLI",
  "author": "Tobias Strebitzer <tobias.strebitzer@atomic.bi.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/lark.git"
  },
  "type": "module",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "bin": {
    "lark-cli": "./build/cli.mjs",
    "lark-mcp": "./build/mcp.mjs",
    "lark-serve": "./build/serve.mjs"
  },
  "exports": {
    ".": {
      "import": "./build/index.mjs",
      "types": "./build/index.d.mts"
    },
    "./cli": {
      "import": "./build/cli.mjs",
      "types": "./build/cli.d.mts"
    },
    "./mcp": {
      "import": "./build/mcp.mjs",
      "types": "./build/mcp.d.mts"
    },
    "./serve": {
      "import": "./build/serve.mjs",
      "types": "./build/serve.d.mts"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/serve.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@silkweave/cli": "^3.1.0",
    "@silkweave/core": "^3.1.0",
    "@silkweave/mcp": "^3.1.0",
    "xmlbuilder2": "^4.0.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "oauth-callback": "^1.2.5",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
